{
  "name": "@forge/agents",
  "version": "0.0.0",
  "private": true,
  "description": "The four Forge sub-agents: Schema Smith, Tool Coder, Inspector, Shipper, plus the Orchestrator manager.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema-smith": {
      "types": "./dist/schema-smith.d.ts",
      "default": "./dist/schema-smith.js"
    },
    "./tool-coder": {
      "types": "./dist/tool-coder.d.ts",
      "default": "./dist/tool-coder.js"
    },
    "./inspector": {
      "types": "./dist/inspector.d.ts",
      "default": "./dist/inspector.js"
    },
    "./shipper": {
      "types": "./dist/shipper.d.ts",
      "default": "./dist/shipper.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@forge/connectors": "workspace:*",
    "@forge/db": "workspace:*",
    "@forge/notion-client": "workspace:*",
    "@forge/ntn-wrapper": "workspace:*",
    "@forge/safety": "workspace:*",
    "@typescript-eslint/parser": "8.16.0",
    "@vercel/blob": "2.3.3",
    "zod": "3.23.8"
  },
  "peerDependencies": {
    "resend": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "resend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
