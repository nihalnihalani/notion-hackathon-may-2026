{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "lib": ["ES2022", "DOM"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "../safety/node_modules/@types"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test", "**/*.test.ts"]
}
