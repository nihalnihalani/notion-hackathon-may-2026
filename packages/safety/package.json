{
  "name": "@forge/safety",
  "version": "0.0.0",
  "private": true,
  "description": "AST scanner + forbidden-API list + schema validator for generated agent code (code-gen safety net).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@typescript-eslint/parser": "8.16.0",
    "@typescript-eslint/utils": "8.16.0"
  },
  "devDependencies": {
    "@types/node": "20.17.9",
    "@vitest/coverage-v8": "2.1.8",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
