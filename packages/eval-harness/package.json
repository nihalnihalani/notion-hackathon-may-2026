{
  "name": "@forge/eval-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Promptfoo configs + golden inputs for each sub-agent. Catches prompt regressions before deploy.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "default": "./dist/runner.js"
    },
    "./baseline": {
      "types": "./dist/baseline.d.ts",
      "default": "./dist/baseline.js"
    }
  },
  "files": ["dist", "evals"],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx src/cli.ts run",
    "eval:dry-run": "tsx src/cli.ts validate",
    "eval:report": "tsx src/cli.ts report",
    "baseline:check": "tsx src/cli.ts baseline-check",
    "baseline:update": "tsx src/cli.ts baseline-update"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.17.6",
    "@vitest/coverage-v8": "2.1.8",
    "js-yaml": "4.1.0",
    "promptfoo": "^0.121.0",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
