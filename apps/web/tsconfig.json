{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.next/.tsbuildinfo",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    },
    // Next.js's compiler + React Server Components reuse the same module file
    // for both the server graph and the client graph; with `verbatimModuleSyntax`
    // on, the compiler refuses to elide `import` statements that only contribute
    // types, which breaks RSC's "server-only" boundary inference. Disable it
    // here while keeping `isolatedModules` (still inherited from base) so we
    // retain per-file transpilation guarantees.
    "verbatimModuleSyntax": false
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "middleware.ts",
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
