# Sentry env vars required for production observability.
# Copy the relevant lines into your Vercel project env (or `.env.local` for
# local prod-mode testing). All of these are read by either
# `instrumentation.ts`, `instrumentation-client.ts`, or `next.config.ts`.
#
# ─── Required to enable any Sentry capture ───────────────────────────────
# Server + edge DSN. Same project as the public DSN; lives only on the
# server, never exposed to the browser bundle.
SENTRY_DSN=

# Public DSN consumed by `instrumentation-client.ts`. Yes, the value is the
# same as SENTRY_DSN — Next.js only inlines NEXT_PUBLIC_* vars into the
# client bundle, so we mirror it explicitly.
NEXT_PUBLIC_SENTRY_DSN=

# ─── Required for source-map upload at build time ────────────────────────
# Auth token scoped to `project:releases`. Create one at:
#   https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# Org + project slug. Visible in your Sentry URL: sentry.io/<org>/<project>/
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Optional ────────────────────────────────────────────────────────────
# Override the auto-detected environment tag (defaults to VERCEL_ENV or
# NODE_ENV). Useful for tagging preview deploys distinctly from prod.
SENTRY_ENVIRONMENT=

# Explicit release identifier. When unset we fall back to
# VERCEL_GIT_COMMIT_SHA inside `instrumentation.ts` so each deploy gets a
# unique release in Sentry. Set this only when you want a semver-style tag.
SENTRY_RELEASE=

# Opt-in Session Replay. Defaults to OFF; flip to `1` to enable replay
# capture. Even then, all DOM text + inputs are masked and media is blocked
# by the integration config in `instrumentation-client.ts`.
NEXT_PUBLIC_SENTRY_REPLAY_ENABLED=
