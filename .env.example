# =============================================================================
# Forge — Environment Variables
# Copy to .env (or .env.local for apps/web) and fill in real values.
# Every variable listed here is REQUIRED unless explicitly marked optional.
# =============================================================================

# ----- App ------------------------------------------------------------------
# Public origin of the deployed Forge app — used to build OAuth callback URLs,
# webhook URLs, and absolute links in transactional email.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Anthropic ------------------------------------------------------------
# Primary model provider for all 4 sub-agents (Schema Smith, Tool Coder,
# Inspector, Shipper). Routed via Vercel AI Gateway in production.
ANTHROPIC_API_KEY=

# ----- OpenAI ---------------------------------------------------------------
# Fallback model + embeddings (text-embedding-3-large) for prompt similarity cache.
OPENAI_API_KEY=
# Required when OPENAI_API_KEY is an org-scoped key (sk-proj-…); requests fail
# with "no default project" without it.
OPENAI_ORG_ID=

# ----- Notion Developer Platform -------------------------------------------
# OAuth client id issued by the Notion integration dashboard.
NOTION_OAUTH_CLIENT_ID=
# OAuth client secret paired with NOTION_OAUTH_CLIENT_ID; never exposed to the client.
NOTION_OAUTH_CLIENT_SECRET=
# Absolute URL Notion redirects back to after OAuth consent — must match the
# value configured in the Notion integration dashboard exactly.
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/notion/callback
# Shared secret used to verify the HMAC signature on incoming Notion webhooks.
NOTION_WEBHOOK_SECRET=
# Pin of the `ntn` CLI version Forge tests + ships against (semver range, e.g. "0.1.x").
NTN_VERSION=0.1.x

# ----- Clerk (auth) ---------------------------------------------------------
# Server-side Clerk secret for session verification + admin actions.
CLERK_SECRET_KEY=
# Public Clerk key exposed to the browser for sign-in widgets.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Signing secret for Clerk → Forge webhooks (user.created, organization.created
# events drive workspace provisioning).
CLERK_WEBHOOK_SECRET=
# Clerk's JWT public key (JWKS-style PEM) used to verify session tokens
# server-side without an extra round-trip to Clerk's API.
CLERK_JWT_KEY=

# ----- PlanetScale (Postgres) ----------------------------------------------
# Single connection string for the source-of-truth database used by Prisma.
DATABASE_URL=

# ----- Vercel ---------------------------------------------------------------
# AI Gateway API key — routes Anthropic + OpenAI calls with cost tracking.
VERCEL_AI_GATEWAY_API_KEY=
# Blob read/write token used to archive generated TypeScript artifacts.
VERCEL_BLOB_READ_WRITE_TOKEN=
# Edge Config connection string powering feature flags + kill switches.
VERCEL_EDGE_CONFIG=

# ----- Observability --------------------------------------------------------
# Sentry DSN for server-side error reporting (Vercel functions + sandbox).
SENTRY_DSN=
# Sentry DSN exposed to the browser for client-side error reporting.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token used by @sentry/nextjs to upload source maps at build time.
SENTRY_AUTH_TOKEN=
# Sentry organization slug (e.g. "forge-dev") — required for source-map upload.
SENTRY_ORG=
# Sentry project slug (e.g. "forge-web") — required for source-map upload.
SENTRY_PROJECT=
# PostHog server-side key for funnel + billing event capture.
POSTHOG_KEY=
# PostHog browser key for client-side analytics + feature flags.
NEXT_PUBLIC_POSTHOG_KEY=

# ----- Email ----------------------------------------------------------------
# Resend API key for transactional email (deploy success, weekly digest, receipts).
RESEND_API_KEY=
# Verified "From" address registered with Resend; sending fails 403 without it.
RESEND_FROM_EMAIL=forge@example.com

# ----- Rate limiting --------------------------------------------------------
# Upstash Redis REST URL for per-user + per-workspace rate limiting.
UPSTASH_REDIS_REST_URL=
# Upstash Redis REST token paired with UPSTASH_REDIS_REST_URL.
UPSTASH_REDIS_REST_TOKEN=

# ----- MiniMax --------------------------------------------------------------
# Voice-to-text + image generation API key for the multimodal input + agent avatars.
MINIMAX_API_KEY=
# MiniMax group id — required alongside MINIMAX_API_KEY on every request.
MINIMAX_GROUP_ID=

# ----- Stripe (billing) -----------------------------------------------------
# Server-side Stripe secret for the billing meter + future paid tier.
STRIPE_SECRET_KEY=
# Webhook signing secret for Stripe → Forge events (invoice.paid, etc.).
STRIPE_WEBHOOK_SECRET=

# ----- Inngest (backup orchestration, optional) -----------------------------
# Event ingest key for the backup pipeline that mirrors Vercel Workflow runs.
INNGEST_EVENT_KEY=   # optional
# Signing secret for Inngest's HTTP transport when proxied through Forge.
INNGEST_SIGNING_KEY= # optional

# ----- Internal -------------------------------------------------------------
# Bearer token required to call internal admin endpoints (e.g. /api/forge/log).
# Generate with: `openssl rand -hex 32`. Rotate the literal REPLACE_ME below in
# every environment — verify-env will refuse to start until it changes.
FORGE_INTERNAL_TOKEN=REPLACE_ME
