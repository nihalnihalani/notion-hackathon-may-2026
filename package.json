{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "description": "Forge — Notion Custom Agent Studio. Describe an agent in plain English, ship a deployed Custom Agent in 90 seconds.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "format:check:changed": "bash scripts/ci/check-format-changed.sh",
    "dev": "turbo run dev --parallel",
    "verify:env": "tsx scripts/verify-env.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.16.0",
    "@typescript-eslint/parser": "8.16.0",
    "dotenv": "^16.4.7",
    "eslint": "9.16.0",
    "eslint-plugin-unicorn": "56.0.1",
    "node-gyp": "^12.3.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "turbo": "2.3.3",
    "typescript": "5.7.2",
    "typescript-eslint": "8.16.0",
    "zod": "3.23.8"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.25.76",
      "devalue@>=5.6.3 <=5.8.0": "5.8.1",
      "undici@>=7.0.0 <7.24.0": "7.24.0"
    }
  }
}
